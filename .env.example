# ============================================================
# Axiom Space — Environment Variables Template
# Copy to .env.local for local development, or .env for prod.
# ============================================================

# ---------- Database (required) ----------
# Local development uses docker-compose.yml -> postgres.
DATABASE_URL="postgresql://axiom:axiom_dev_password@localhost:5433/axiom?schema=public"

# ---------- App URLs (required in production) ----------
# Public app URL — used by frontend to call /api/* and by SSE.
# In dev this defaults to http://localhost:3000 in code.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Better Auth base URL — must match where the auth handler is mounted.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# ---------- Better Auth secret (REQUIRED for production) ----------
# Generate with:  openssl rand -hex 32
BETTER_AUTH_SECRET="change-me-to-a-random-32-byte-hex-string"

# ---------- AI Provider (required for Agent / Forge / Oracle) ----------
# Single source of truth. Legacy VITE_AI_* names are still read as
# fallback but new code should use these.
AI_PROVIDER="openai"             # openai | anthropic | google | cerebras | zai
AI_MODEL="gpt-4o-mini"
AI_API_KEY=""

# ---------- Redis / Jobs ----------
REDIS_URL="redis://localhost:6379"

# ---------- Docker service defaults ----------
POSTGRES_USER="axiom"
POSTGRES_PASSWORD="axiom_dev_password"
POSTGRES_DB="axiom"
POSTGRES_PORT="5433"
REDIS_PORT="6379"
LIGHTRAG_PORT="9621"
OLLAMA_PORT="11434"
OLLAMA_EMBEDDING_MODEL="bge-m3:latest"

# ---------- LightRAG Sidecar (optional) ----------
# AXIOM remains the source of truth. LightRAG stores derived indexes only.
LIGHTRAG_BASE_URL="http://localhost:9621"
LIGHTRAG_API_KEY=""
LIGHTRAG_WORKSPACE_PREFIX="axiom"
LIGHTRAG_TIMEOUT_MS="30000"
LIGHTRAG_INDEX_TIMEOUT_MS="180000"
LIGHTRAG_DELETE_TIMEOUT_MS="120000"
LIGHTRAG_INDEX_POLL_MS="3000"

# Enable after the vault has been indexed.
LIGHTRAG_CHAT_CONTEXT="true"
LIGHTRAG_CHAT_TOP_K="8"
LIGHTRAG_CHAT_CONTEXT_LIMIT="6000"

# LightRAG model config. These are intentionally separate from AXIOM's chat
# model config because RAG indexing needs a real embedding model.
LIGHTRAG_LLM_BINDING="openai"
LIGHTRAG_LLM_BINDING_HOST="https://api.deepseek.com/v1"
LIGHTRAG_LLM_BINDING_API_KEY=""
LIGHTRAG_LLM_MODEL="deepseek-v4-flash"
LIGHTRAG_KEYWORD_LLM_MODEL="deepseek-v4-flash"
LIGHTRAG_QUERY_LLM_MODEL="deepseek-v4-flash"
LIGHTRAG_EMBEDDING_BINDING="ollama"
LIGHTRAG_EMBEDDING_BINDING_HOST="http://ollama:11434"
LIGHTRAG_EMBEDDING_BINDING_API_KEY=""
LIGHTRAG_EMBEDDING_MODEL="bge-m3:latest"
LIGHTRAG_EMBEDDING_DIM="1024"
LIGHTRAG_EMBEDDING_TOKEN_LIMIT="8192"

# ---------- Vault file storage ----------
# Used by LocalFSAdapter when the agent runs in filesystem mode.
# Web deployments should leave this as default and rely on DbAdapter.
VAULT_PATH="./vault"

# ---------- Dev-only ----------
# When DEV_MODE=true, server picks the first user automatically
# if no session cookie is present. NEVER set this in production.
DEV_MODE="false"
