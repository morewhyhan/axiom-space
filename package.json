{
  "name": "nextjs-with-hono",
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "dev:web": "next dev -p 3000",
    "dev:infra": "docker compose up -d postgres redis ollama lightrag",
    "test:acceptance": "node --import tsx test/acceptance/run-all.ts",
    "test:acceptance:api": "node --import tsx test/acceptance/api-rpc-contracts.test.ts",
    "test:acceptance:agent": "node --import tsx test/acceptance/agent-runtime-contracts.test.ts",
    "test:acceptance:db": "node --import tsx test/acceptance/db-smoke.test.ts && node --import tsx test/acceptance/db-contracts.test.ts",
    "test:acceptance:sidecar": "node --import tsx test/acceptance/sidecar-contracts.test.ts",
    "test:acceptance:ui-state": "node --import tsx test/acceptance/ui-state-contracts.test.ts",
    "test:acceptance:full": "pnpm test:acceptance && pnpm test:acceptance:db",
    "test:acceptance:deep": "pnpm test:acceptance:full && pnpm test:acceptance:api && pnpm test:acceptance:agent && pnpm test:acceptance:sidecar && pnpm test:acceptance:ui-state",
    "test:acceptance:list": "node --import tsx test/acceptance/list-cases.ts",
    "test:e2e:sdd": "playwright test test/e2e/sdd-ui.spec.ts",
    "test:e2e:a3-browser-use": "HOME=/tmp/axiom-browser-use-home BROWSER_USE_CONFIG_DIR=/tmp/axiom-browser-use-config /tmp/axiom-browser-use-venv/bin/python scripts/a3_browser_use.py",
    "jobs:worker": "node --import tsx scripts/jobs-worker.ts",
    "predev": "node scripts/bootstrap-dev.mjs && prisma generate",
    "build": "node scripts/bootstrap-dev.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/bootstrap-dev.mjs && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:seed:demo": "node --env-file=.env scripts/demo-reset-ui.mjs",
    "db:seed:a3-golden": "node --import tsx scripts/seed-a3-golden.ts",
    "db:seed:a3-inventory": "node --import tsx scripts/seed-a3-inventory.ts",
    "db:seed:cs408": "node --import tsx scripts/seed-cs408.ts",
    "db:seed:career": "node --import tsx scripts/seed-career.ts",
    "seed:career": "node --import tsx scripts/seed-career.ts",
    "db:verify:cs408": "node scripts/verify-cs408-seed.mjs",
    "demo:serve": "node scripts/demo-serve.mjs",
    "agent:eval": "tsx scripts/eval-agent-production.ts",
    "check:demo": "node --import tsx scripts/test/check-demo.ts",
    "check:a3-golden": "node --import tsx scripts/test/check-a3-golden.ts",
    "check:a3-inventory": "node --import tsx scripts/test/check-a3-inventory.ts",
    "check:a3-inventory:ui": "node --import tsx scripts/test/check-a3-inventory-ui.ts",
    "demo:preflight": "pnpm check:a3-golden && node scripts/demo-preflight.mjs",
    "check:a3-live-loop": "node --import tsx scripts/test/run-a3-live-loop.ts",
    "record:a3-golden": "node --import tsx scripts/test/record-a3-golden.ts"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.4.1",
    "@hono/zod-openapi": "^1.2.4",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.56.2",
    "archiver": "^8.0.0",
    "better-auth": "^1.5.6",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "events": "^3.3.0",
    "global-agent": "^4.1.3",
    "gsap": "^3.15.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.6.2",
    "html-to-docx": "^1.8.0",
    "https-proxy-agent": "^9.0.0",
    "katex": "^0.17.0",
    "ky": "^1.7.2",
    "lucide-react": "^1.7.0",
    "marked": "^18.0.4",
    "mermaid": "^11.15.0",
    "nanoid": "3",
    "next": "14.2.5",
    "next-themes": "^0.4.4",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^25.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "2.15.4",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "undici": "^7.25.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "18.11.18",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.10",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.5.8",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "packageManager": "pnpm@9.11.0"
}
