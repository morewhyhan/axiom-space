// Axiom - Cognitive Operating System
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// BetterAuth models
// ═══════════════════════════════════════════════

model account {
  id           String   @id @default(uuid())
  userId       String
  accountId    String
  providerId   String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ═══════════════════════════════════════════════
// Vault & Cards — MD 文件存储在数据库中
// 一个用户一个 vault，每张卡片存一行
// content 存完整 Markdown，Agent 通过 IFileStorage 读写
// ═══════════════════════════════════════════════

// 知识域/星团 — 对应 Galaxy 中的簇
model cluster {
  id        String   @id @default(uuid())
  vaultId   String
  name      String              // 如 "数据结构", "操作系统"
  color     String   @default("#a855f7") // hex 颜色
  position  Int      @default(0) // 排序位置
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vault vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  cards card[]

  @@index([vaultId])
}

model card {
  id        String   @id @default(uuid())
  vaultId   String
  clusterId String?
  path      String   // 文件路径，如 "数据结构/线性表.md"
  content   String   // 完整 Markdown 内容
  type      String   @default("fleeting") // "literature" | "fleeting" | "permanent"
  title     String?
  tags      String?  // JSON 数组字符串
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vault   vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  cluster cluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)

  edgesFrom edge[] @relation("EdgeSource")
  edgesTo   edge[] @relation("EdgeTarget")
  learningPathSteps learningPathStep[]

  @@unique([vaultId, path])
  @@index([vaultId, type])
  @@index([clusterId])
}

// 卡片间关联 — 用于 Galaxy 图谱连线
model edge {
  id        String   @id @default(uuid())
  vaultId   String
  sourceId  String
  targetId  String
  weight    Float    @default(1.0)
  type      String   @default("related") // "related" | "prerequisite" | "derived" | "counter"
  createdAt DateTime @default(now())

  vault  vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  source card  @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target card  @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([vaultId])
  @@index([sourceId])
  @@index([targetId])
}

// ═══════════════════════════════════════════════
// Learning — 学习会话与消息持久化
// ═══════════════════════════════════════════════

model learningSession {
  id        String             @id @default(uuid())
  userId    String
  vaultId   String?
  domain    String
  concept   String
  status    String             @default("idle") // idle | active | paused | completed | interrupted
  phase     String             @default("explore")
  outcome   String?
  metadata  String?            // JSON
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user     user              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault    vault?            @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  messages learningMessage[]

  @@index([userId])
  @@index([userId, vaultId])
  @@index([vaultId])
}

model learningMessage {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // "system" | "user" | "assistant" | "tool_result"
  content   String
  timestamp DateTime @default(now())
  metadata  String?  // JSON

  session learningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model learningPathStep {
  id               String   @id @default(uuid())
  pathId           String
  cardId           String?
  order            Int
  title            String
  description      String?
  concept          String?
  chapter          String?  // 概念组名称，同一组步骤的 chapter 值相同
  status           String   @default("locked") // locked | available | learning | completed | mastered
  mastery          Int      @default(0)
  estimatedMinutes Int?
  prerequisites    String?  // JSON array of step IDs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  path   learningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  card   card?        @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([pathId])
}

// ═══════════════════════════════════════════════
// Agent Session — 替代 .axiom/sessions/{id}.json
// ═══════════════════════════════════════════════

model agentSession {
  id        String   @id
  vaultId   String
  name      String
  messages  String   // JSON: 消息数组
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vault vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId])
}

// ═══════════════════════════════════════════════
// Vault Memory — 替代 .axiom/memories/MEMORY.md
// ═══════════════════════════════════════════════

model vaultMemory {
  id        String   @id @default(uuid())
  vaultId   String
  key       String
  value     String
  category  String   // preference | style | context | fact
  createdAt DateTime @default(now())

  vault vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, key])
  @@index([vaultId])
}

// ═══════════════════════════════════════════════
// Vault Capability — 替代 .axiom/capabilities.json
// ═══════════════════════════════════════════════

model vaultCapability {
  id           String   @id @default(uuid())
  vaultId      String
  concept      String
  masteryLevel Int      @default(10)
  status       String   @default("learning") // known | learning | mastered
  lastAccessed DateTime @default(now())
  accessCount  Int      @default(1)
  weakAreas    String   @default("[]")   // JSON array
  strongAreas  String   @default("[]")   // JSON array

  vault vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, concept])
  @@index([vaultId])
}

// ═══════════════════════════════════════════════
// Vault Skill — 替代 .axiom/skills/**/*.md
// ═══════════════════════════════════════════════

model vaultSkill {
  id            String   @id @default(uuid())
  vaultId       String
  name          String
  description   String
  category      String   @default("未分类")
  tags          String   @default("[]")        // JSON array
  confidence    Float    @default(0.5)
  demonstratedAt DateTime @default(now())
  evidence      String   @default("")
  source        String   @default("conversation")

  vault vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, name])
  @@index([vaultId])
}

// ═══════════════════════════════════════════════════════════════
// P1: 6 维学习画像、路径调整、资源推送
// ═══════════════════════════════════════════════════════════════

// 教育画像历史记录
model EducationProfileHistory {
  id        String   @id @default(uuid())
  vaultId   String
  profile   String   // JSON: EducationProfile（6维数据 + 历史）
  snapshot  String?  // 简要快照用于快速查询
  createdAt DateTime @default(now())

  vault vault @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([vaultId, createdAt])
  @@index([createdAt])
}

// 学习路径调整历史
model PathAdjustmentHistory {
  id          String   @id @default(uuid())
  pathId      String
  adjustment  String   // JSON: DynamicAdjustment（调整类型、原因、变化）
  trigger     String   // session_end | assessment | manual
  appliedAt   DateTime @default(now())
  feedback    String?  // JSON: 用户反馈

  path learningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)

  @@index([pathId, appliedAt])
  @@index([appliedAt])
}

// 资源推送记录
model PushRecord {
  id              String   @id @default(uuid())
  userId          String
  vaultId         String?
  resources       String   // JSON: PushableResource[]（推送的资源列表）
  trigger         String   // stage_completion | assessment_pass | low_dimension | scheduled
  reason          String   // 推送理由
  sentAt          DateTime @default(now())
  expiresAt       DateTime // 推送过期时间（30天后）
  viewedAt        DateTime?
  engagedCount    Int      @default(0)
  feedback        String?  // JSON: { engagedResourceIds: [], feedbackText: '' }

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault vault? @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@index([userId, vaultId])
  @@index([userId, sentAt])
  @@index([vaultId])
  @@index([sentAt])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════
// Complete model definitions (at end)
// ═══════════════════════════════════════════════

model user {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions               session[]
  accounts               account[]
  vaults                 vault[]
  learningSessions       learningSession[]
  learningPaths          learningPath[]
  pushRecords            PushRecord[]
}

model session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model vault {
  id           String   @id @default(uuid())
  userId       String
  name         String   @default("My Vault")
  profileCache String?  // JSON — 认知画像缓存，避免每次重算
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                      user                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards                     card[]
  clusters                  cluster[]
  edges                     edge[]
  learningSessions          learningSession[]
  agentSessions             agentSession[]
  vaultMemories             vaultMemory[]
  vaultCapabilities         vaultCapability[]
  vaultSkills               vaultSkill[]
  learningPaths             learningPath[]
  educationProfileHistory   EducationProfileHistory[]
  pushRecords               PushRecord[]


  @@index([userId])
}

model learningPath {
  id          String   @id @default(uuid())
  userId      String
  vaultId     String
  name        String
  topic       String
  description String?
  difficulty  String   @default("beginner")
  totalSteps  Int      @default(0)
  doneSteps   Int      @default(0)
  status      String   @default("active") // active | completed | archived
  source      String   @default("ai")     // ai | graph | manual
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps              learningPathStep[]
  user               user                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault              vault                  @relation(fields: [vaultId], references: [id], onDelete: Cascade)
  adjustmentHistory  PathAdjustmentHistory[]

  @@index([userId, vaultId])
}
